/*
	Micromagnetic standard problem 4,
	with 3D discretization and minimize instead of relax
*/

// geometry
	Nx = 128
Ny = 32
Nz = 2
	dx = 500e-9/128
dy = 125e-9/32
dz = 3e-9/2

// material
	Msat = 800e3
	Aex = 13e-12
	m  = uniform(1, .1, 0)

// minimize
	minimize()
	TOL := 1e-3
	expectv("m", m.average(), vector(0.9669952, 0.12521563, 0), TOL)

