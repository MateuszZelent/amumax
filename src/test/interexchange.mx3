/*
	Test antiferromagnetic exchange between two regions
*/

Nx = 128
Ny = 32
Nz = 1
dx = 500e-9/128
dy = 125e-9/32
dz = 3e-9

Msat = 800e3
m  = uniform(1, .1, 0)

defregion(1, Yrange(0, inf))
defregion(2, Yrange(-inf, 0))
ext_ScaleExchange(1, 2, -1.0)   // AFM exchange

Aex = 13e-12

alpha = 3
run(10e-9) 
expectv("m", m.average(), vector(0,  0.114170685410499, 0), 1e-5)


