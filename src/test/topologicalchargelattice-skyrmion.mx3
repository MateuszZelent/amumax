/* 
	Test topological charge calculation:
	for bubble/skyrmion S = -1,1,2...
	Based on topologicalcharge-skyrmion.mx3
*/

tol := 0.005

Nx = 64
Ny = 128
Nz = 8
dx = 3e-9
dy = 1.5e-9
dz = 8e-9

// aka CoPt
Msat    = 1000e3
Aex     = 10e-12
anisU   = vector(0, 0, 1)
Ku1     = 0.65e6
alpha   = 1

m = blochskyrmion(1, 1).scale(4,4,1)
steps(500)
expect("Skyrmion number" , ext_topologicalchargelattice,  1.0, tol)

m = blochskyrmion(-1, 1).scale(4,4,1)
steps(500)
expect("Skyrmion number" , ext_topologicalchargelattice,  1.0, tol)

m = blochskyrmion(1, -1).scale(4,4,1)
steps(500)
expect("Skyrmion number" , ext_topologicalchargelattice,  -1.0, tol)

m = blochskyrmion(-1, -1).scale(4,4,1)
steps(500)
expect("Skyrmion number" , ext_topologicalchargelattice,  -1.0, tol)
