/* 
	Test exchange-demag competition by relaxing a vortex.
	Use elongated cells to stress the implementation.
*/

d := 100e-9
N := 32
Nx = N
Ny = 2*N
Nz = N/4
dx = d/N
dy = d/(2*N)
dz = 2*d/N

msat  = 800e3
aex   = 13e-12
alpha = 3
m     = vortex(1, 1)

relax()
expect("mz", m.comp(2).average(), 0.016988324001431, 1e-3)


