/*
	Test magnetization stretch upon resize.
*/

Nx = 128
Ny = 32
Nz = 1
dx = 500e-9/128
dy = 125e-9/32
dz = 3e-9

Msat = 800e3
Aex = 13e-12
m  = uniform(1, .1, 0)

alpha = 3
//MaxErr = 1e-4
RunWhile(MaxTorque > 1e-4)
run(1e-9)

expectv("m", m.average(), vector(0.96696, 0.12528, 0), 1e-3)

Nx = 128*2
Ny = 32*2
Nz = 2
dx = 500e-9/(128*2)
dy = 125e-9/(32*2)
dz = 3e-9/2

expectv("m", m.average(), vector(0.96696, 0.12528, 0), 1e-3)

run(1e-9)

expectv("m", m.average(), vector(0.96696, 0.12528, 0), 1e-3)

