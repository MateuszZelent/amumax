/*
	Test smooth geometry by evaluating the surface of a circle.
*/

N := 10
Nx = 2*N
Ny = N
Nz = 1
c := 1e-9
dx = c
dy = 2*c
dz = 3*c

disk := circle(2*N*c)

// No smoothing: rough approximation
edgesmooth=0
setgeom(disk)
expect("staircase", geom.Average(), 0.8, 1e-3)

// Smoothing: good approximation
edgesmooth=10
setgeom(disk)
expect("smooth", geom.Average(), pi/4, 1e-3)
