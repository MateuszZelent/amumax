/* 
	Test for tripping the solver with an instable equilibrium start magnetization.
	Reported by Mykola Dvornik, Feb. 2015.
*/

Nx = 5
Ny = 1
Nz = 1
dx = 1e-9
dy = 1e-9
dz = 1e-9

Msat    = 1000e3
Aex     = 10e-12
anisU   = vector(0, 0, 1)
Ku1     = 1.3e6
alpha   = 0.02

m = uniform(0.0, 0.0, 1.0)
relax()

m = uniform(0.0, 0.0, -1.0)
relax() // used to fail here.
